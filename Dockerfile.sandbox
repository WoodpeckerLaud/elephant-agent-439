FROM python:3.12-slim

# Minimal sandbox image for Elephant Agent
# Provides: bash, coreutils, python3, pip

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        bash \
        coreutils \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Create sandbox user (non-root)
RUN groupadd -r sandbox && \
    useradd -r -g sandbox -d /home/sandbox -s /bin/bash sandbox

# Create workspace mount point
RUN mkdir -p /workspace && \
    chown sandbox:sandbox /workspace

WORKDIR /workspace

# Default: keep container alive
CMD ["sleep", "infinity"]
